# Sooko DevOS — Environment Configuration
# Copy this file to .env.local and fill in your values

# Agent mode: "mock" (default) or "live" (requires Copilot SDK + keys)
COPILOT_SDK_MODE=mock

# BYOK API Keys (required for live mode)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_AI_API_KEY=...
